# clearly makes git better

[column]
        ui = auto
[branch]
        sort = -committerdate
[tag]
        sort = version:refname
[init]
        defaultBranch = main
[diff]
        algorithm = histogram
        colorMoved = plain
        mnemonicPrefix = true
[push]
        autoSetupRemote = true
        followTags = true
[fetch]
        prune = true
        pruneTags = true
        all = true

# why the hell not?

[help]
        autocorrect = prompt

[commit]
        verbose = true

[rerere]
        enabled = true
        autoupdate = true

[core]
        excludesfile = ~/.gitignore
        editor = vim
        autocrlf = input
        pager = delta

[rebase]
        autoSquash = true
        autoStash = true
        updateRefs = true

[interactive]
        diffFilter = delta --color-only

[delta]
        navigate = true
        dark = true

[merge]
        conflictStyle = zdiff3

[user]
        name = Leon Handreke
        email = leonh@ndreke.de
        signingkey = 02497EB1
        sign-commits = true

[github]
        user = leonhandreke

[alias]
        co = checkout
        b = checkout --track -b

[credential]
        helper = store

[pull]
        ff = only
