# clearly makes git better

[column]
        ui = auto
[branch]
        sort = -committerdate
[tag]
        sort = version:refname
[init]
        defaultBranch = main
[diff]
        algorithm = histogram
        colorMoved = plain
        mnemonicPrefix = true
        renames = true
[push]
        default = simple
        autoSetupRemote = true
        followTags = true
[fetch]
        prune = true
        pruneTags = true
        all = true

# why the hell not?

[help]
        autocorrect = prompt

[commit]
        verbose = true

[rerere]
        enabled = true
        autoupdate = true

[core]
        excludesfile = ~/.gitignore

[rebase]
        autoSquash = true
        autoStash = true
	updateRefs = true


[user]
	name = Leon Handreke
	email = leonh@ndreke.de
	signingkey = 02497EB1
	sign-commits = true

[core]
	editor = vim
	autocrlf = input
        pager = delta

[interactive]
        diffFilter = delta --color-only

[delta]
        navigate = true  # use n and N to move between diff sections
        dark = true      # or light = true, or omit for auto-detection

[merge]
        conflictStyle = zdiff3

[github]
	user = leonhandreke

[push]
	default = simple
	autoSetupRemote = true

[alias]
	co = checkout
	b = checkout --track -b

[credential]
	helper = store

[pull]
	ff = only
